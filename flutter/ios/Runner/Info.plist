<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<!-- app_links(DeepLinkService) 가 /r/{uuid} universal link 를 직접 처리.
		     Flutter 내장 딥링킹을 끄지 않으면 GoRouter 가 같은 링크를 자체 navigate
		     해 ReportPage 가 2장 push 된다. -->
		<key>FlutterDeepLinkingEnabled</key>
		<false/>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>관상은 과학이다</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>관상은 과학이다</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleURLTypes</key>
		<array>
			<dict>
				<key>CFBundleTypeRole</key>
				<string>Editor</string>
				<key>CFBundleURLName</key>
				<string>com.scienceintegration.facely.auth</string>
				<key>CFBundleURLSchemes</key>
				<array>
					<string>facely</string>
				</array>
			</dict>
			<!-- 카카오 메시지 '참여하기' 앱 직접 실행(executionParams) 수신용 스킴.
			     kakao{NATIVE_APP_KEY}://kakaolink → DeepLinkService 가 처리. -->
			<dict>
				<key>CFBundleTypeRole</key>
				<string>Editor</string>
				<key>CFBundleURLName</key>
				<string>com.scienceintegration.facely.kakaolink</string>
				<key>CFBundleURLSchemes</key>
				<array>
					<string>kakao6d20884c9c77d031bc710f1135a7d4a0</string>
				</array>
			</dict>
		</array>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<!-- 카카오 SDK 가 카톡 설치 여부(canOpenURL)를 묻고, 카카오톡 공유/로그인
		     으로 전환할 때 필요한 scheme 화이트리스트. 빠지면 iOS 가
		     isKakaoTalkSharingAvailable() 에 무조건 false 를 돌려줘 공유 시트가
		     안 뜬다. -->
		<key>LSApplicationQueriesSchemes</key>
		<array>
			<string>kakaokompassauth</string>
			<string>kakaotalk</string>
			<string>kakaolink</string>
			<string>kakaoplus</string>
		</array>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>NSCameraUsageDescription</key>
		<string>Camera access is needed for face mesh detection</string>
		<key>NSPhotoLibraryUsageDescription</key>
		<string>앨범에서 사진을 선택하여 관상 분석에 사용합니다</string>
		<!-- AdMob iOS app ID (실 앱 ID). 광고 유닛 ID 는 .env 의
		     ADMOB_REWARDED_UNIT_ID_IOS (slash 형식) 로 별도 관리. -->
		<key>GADApplicationIdentifier</key>
		<string>ca-app-pub-6207520648206097~9925492444</string>
		<key>SKAdNetworkItems</key>
		<array>
			<dict>
				<key>SKAdNetworkIdentifier</key>
				<string>cstr6suwn9.skadnetwork</string>
			</dict>
		</array>
		<key>UIApplicationSceneManifest</key>
		<dict>
			<key>UIApplicationSupportsMultipleScenes</key>
			<false/>
			<key>UISceneConfigurations</key>
			<dict>
				<key>UIWindowSceneSessionRoleApplication</key>
				<array>
					<dict>
						<key>UISceneClassName</key>
						<string>UIWindowScene</string>
						<key>UISceneConfigurationName</key>
						<string>flutter</string>
						<key>UISceneDelegateClassName</key>
						<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
						<key>UISceneStoryboardFile</key>
						<string>Main</string>
					</dict>
				</array>
			</dict>
		</dict>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UIStatusBarHidden</key>
		<false/>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
		</array>
	</dict>
</plist>
